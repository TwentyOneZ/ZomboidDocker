# Nome do servidor/perfil usado nos arquivos em data/Zomboid/Server.
SERVER_NAME=Perspex

# Branch do Project Zomboid Dedicated Server instalada pelo SteamCMD.
# O padrao deste projeto e unstable.
STEAM_BRANCH=unstable

# Quando true, executa SteamCMD a cada inicializacao para instalar/atualizar o servidor.
UPDATE_ON_START=true

# Timezone usado pelo agendamento do backup diario.
TZ=America/Sao_Paulo

# Quando true, para o servidor diariamente, gera backup, move o arquivo e reinicia.
BACKUP_ENABLED=true

# Horario diario do backup no timezone acima. Formato HH:MM.
BACKUP_TIME=04:30

# Tempo maximo, em segundos, para aguardar o shutdown antes de forcar parada.
SHUTDOWN_GRACE_SECONDS=180

# Destino no host para receber o backup movido.
# No Windows, use barras normais para o Docker Compose:
# BACKUP_TARGET_PATH=G:/Meu Drive/Shared/Zomboid
BACKUP_TARGET_PATH=G:/Meu Drive/Shared/Zomboid
